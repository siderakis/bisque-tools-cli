{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bisque.tools/schemas/klaviyo/template.json",
  "title": "Klaviyo Template",
  "description": "YAML shape for integrations/klaviyo/templates/<slug>.yaml",
  "type": "object",
  "required": ["name", "html"],
  "properties": {
    "kind": {
      "type": "string",
      "const": "template"
    },
    "name": {
      "type": "string",
      "description": "Human-readable template name (sent to Klaviyo as attributes.name)."
    },
    "html": {
      "type": "object",
      "required": ["render"],
      "properties": {
        "render": {
          "type": "string",
          "enum": ["exec"],
          "description": "Only `exec` is supported. Runs command and captures stdout as rendered HTML."
        },
        "command": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "argv to execute in the workspace root. stdout is captured as the rendered HTML bytes."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
